<div class="modal fade" id="esqueciSenhaModal" tabindex="-1" aria-labelledby="esqueciSenhaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4 custom-modal-radius">
            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <i class="fa-solid fa-envelope-open-text fa-3x mb-3 modal-icon-color"></i>
                <h4 class="mb-4 modal-title-custom">Recuperar Senha</h4>
                <p class="text-muted text-sm mb-4">Digite o e-mail cadastrado. Enviaremos um código de 6 dígitos para você redefinir sua senha.</p>

                <form asp-controller="Usuarios" asp-action="SolicitarReset" method="post">
                    <div class="mb-4">
                        <input type="email" name="emailRecuperacao" class="form-control bg-light text-center rounded-pill py-2" placeholder="Digite seu e-mail" required>
                    </div>
                    <button type="submit" class="btn w-100 mb-3 text-white fw-bold rounded-pill py-2 btn-login-submit">
                        Enviar Código
                    </button>
                </form>

                <a href="#" class="text-muted text-sm text-decoration-none" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">
                    <i class="fa-solid fa-arrow-left me-1"></i> Voltar para o Login
                </a>
            </div>
        </div>
    </div>
</div>