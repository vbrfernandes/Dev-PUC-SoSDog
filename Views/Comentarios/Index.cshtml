@model IEnumerable<SosDog.Models.Comentario>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Texto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Data_hora)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Usuario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ocorrencia)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Texto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Data_hora)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Usuario.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ocorrencia.Descricao)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ID_Comentario">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ID_Comentario">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ID_Comentario">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
