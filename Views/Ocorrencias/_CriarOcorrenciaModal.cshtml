@model SosDog.Models.Ocorrencia

<div class="modal fade" id="modalOcorrencia" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
            <div class="modal-header border-0 pb-0 justify-content-center position-relative">
                <h4 class="modal-title fw-bold text-dark w-100 text-center mt-2">Reportar Animal</h4>
                <button type="button" class="btn-close position-absolute end-0 top-0 mt-3 me-3" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-controller="Ocorrencias" asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="modal-body px-4 pt-4">
                    
                    <div class="mb-3">
                        <input asp-for="Endereco" class="form-control bg-light text-secondary" placeholder="Localização / Nome da Rua" required style="border: 1px solid #ddd;" />
                    </div>

                    <label class="form-label fw-bold text-dark small mb-2">Tipo de Ocorrência:</label>
                    <div class="d-flex gap-2 mb-3">
                        <input type="radio" class="btn-check" name="Tipo" id="tipoRua" value="Rua" checked>
                        <label class="btn btn-outline-warning w-50 fw-semibold" for="tipoRua">Animal na Rua</label>

                        <input type="radio" class="btn-check" name="Tipo" id="tipoPerdido" value="Perdido">
                        <label class="btn btn-outline-primary w-50 fw-semibold" for="tipoPerdido">Meu Pet Sumiu</label>
                    </div>

                    <div class="row mb-3 gx-2">
                        <div class="col-6">
                            <select asp-for="Porte" class="form-select text-secondary" style="border: 1px solid #ddd;">
                                <option value="" disabled selected>Porte</option>
                                <option value="Pequeno">Pequeno</option>
                                <option value="Médio">Médio</option>
                                <option value="Grande">Grande</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select asp-for="Sexo" class="form-select text-secondary" style="border: 1px solid #ddd;">
                                <option value="" disabled selected>Sexo</option>
                                <option value="Macho">Macho</option>
                                <option value="Fêmea">Fêmea</option>
                                <option value="Não sei">Não sei</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3 gx-2">
                        <div class="col-6">
                            <select asp-for="Sociabilidade" class="form-select text-secondary" style="border: 1px solid #ddd;">
                                <option value="" disabled selected>Estado</option>
                                <option value="Aparentemente Saudável">Aparentemente Saudável</option>
                                <option value="Ferido / Machucado">Ferido / Machucado</option>
                                <option value="Desnutrido">Desnutrido</option>
                                <option value="Em Perigo">Em Perigo</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select asp-for="Faixa_Etaria" class="form-select text-secondary" style="border: 1px solid #ddd;">
                                <option value="" disabled selected>Idade</option>
                                <option value="Filhote">Filhote</option>
                                <option value="Adulto">Adulto</option>
                                <option value="Idoso">Idoso</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Cor_Pelagem" class="form-control text-secondary" placeholder="Cor / Pelagem (Ex: Caramelo)" style="border: 1px solid #ddd;" />
                    </div>

                    <label class="form-label fw-bold text-dark small mb-2">Cuidados fornecidos:</label>
                    <div class="d-flex gap-3 mb-3">
                        <div class="form-check">
                            <input asp-for="Recebeu_Agua" class="form-check-input" type="checkbox" id="checkAgua">
                            <label class="form-check-label text-secondary" for="checkAgua">Dei Água</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Recebeu_Comida" class="form-check-input" type="checkbox" id="checkComida">
                            <label class="form-check-label text-secondary" for="checkComida">Dei Comida</label>
                        </div>
                    </div>

                    <label class="form-label fw-bold text-dark small mb-2">Adicionar Foto:</label>
                    <div class="mb-3">
                        <input type="file" name="Foto_Animal" class="form-control text-secondary" accept="image/*" style="border: 1px solid #ddd;" />
                    </div>

                    <div class="mb-3">
                        <textarea asp-for="Descricao" class="form-control text-secondary" placeholder="Observações e detalhes sobre o animal..." rows="3" required style="border: 1px solid #ddd;"></textarea>
                    </div>

                    <input type="hidden" asp-for="Latitude" id="lat" />
                    <input type="hidden" asp-for="Longitude" id="lng" />

                </div>
                
                <div class="modal-footer border-0 px-4 pb-4 pt-0">
                    <button type="submit" class="btn w-100 text-white fw-bold" style="background-color: #2ecc71; border-radius: 5px; padding: 12px 0; font-size: 16px;">
                        Registrar Marcação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>