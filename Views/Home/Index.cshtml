@model IEnumerable<SosDog.Models.Ocorrencia>
@{
    ViewData["Title"] = "Dashboard de Ocorrências";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<main class="dashboard-container">
    <aside class="left-sidebar">
        <div class="cases-list">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="case-card"
                         data-id="@item.ID_Ocorrencia"
                         data-lat="@item.Latitude"
                         data-lng="@item.Longitude"
                         data-codigo="@item.Codigo_Cachorro"
                         data-sexo="@item.Sexo"
                         data-cor="@item.Cor_Pelagem"
                         data-porte="@item.Porte"
                         data-sociabilidade="@item.Sociabilidade"
                         data-idade="@item.Faixa_Etaria"
                         data-usuario="@item.ID_Usuario"
                         data-alimentacao="@(item.Data_Ultima_Alimentacao.HasValue ? item.Data_Ultima_Alimentacao.Value.ToString("dd/MM/yyyy HH:mm") : "Sem registro")">
                    
                        <img src="@item.Foto_Animal" class="dog-api-img" alt="Foto do Animal">

                        <div class="case-details">
                            <div class="case-header">
                                <span>Id: @item.Codigo_Cachorro</span>
                                <span class="badge badge-green">Saudável</span>
                            </div>
                            <p><strong>Tipo:</strong> @item.Tipo</p>
                            <p class="text-truncate" title="@item.Descricao">
                                <strong>Status:</strong> @item.Sociabilidade - @item.Porte - @item.Sexo
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <i class="fa-solid fa-dog fa-2x mb-2"></i>
                    <p>Nenhuma ocorrência encontrada no sistema.</p>
                </div>
            }
        </div>

        <div class="sidebar-buttons">
            <button class="btn-orange @(User.Identity.IsAuthenticated ? "" : "auth-required")"
                    onclick="@(User.Identity.IsAuthenticated ? "alert('Em desenvolvimento!')" : "")">
                Urgente <i class="fa-solid fa-user-clock"></i>
            </button>
        
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <button type="button" class="btn-orange" data-bs-toggle="modal" data-bs-target="#modalOcorrencia">
                    Reportar Animal <i class="fa-solid fa-pen-to-square"></i>
                </button>
            }
            else
            {
                <button type="button" class="btn-orange" data-bs-toggle="modal" data-bs-target="#loginModal">
                    Reportar Animal <i class="fa-solid fa-pen-to-square"></i>
                </button>
            }
        </div>
    </aside>

    <section class="main-map-area">
        <div id="map"></div>
    </section>

    <aside class="right-sidebar dog-profile-sidebar" id="painel-detalhes" style="display: none;">
        <div class="profile-img-wrap">
            <img id="sidebar-foto" src="/img/placeholder-dog.png" alt="Cachorro">
        </div>
        <div class="profile-header">
            <h2 id="sidebar-titulo-id">ID do Cachorro</h2>
            <i class="fa-regular fa-pen-to-square edit-icon @(User.Identity.IsAuthenticated ? "" : "auth-required")"
               id="btn-editar-ocorrencia"
               style="cursor: pointer;"
               title="Editar Ocorrência"></i>

        </div>
        <hr class="profile-divider">
        <div class="profile-section">
            <h3 class="section-title">Status do Animal</h3>
            <div class="status-box">
                <div class="status-item">
                    <span class="status-label">Sexo:</span>
                    <span class="status-data" id="sidebar-sexo">---</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Cor:</span>
                    <span class="status-data" id="sidebar-cor">---</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Porte:</span>
                    <span class="status-data" id="sidebar-porte">---</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Situação:</span>
                    <span class="status-data" id="sidebar-sociabilidade">---</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Faixa Etária:</span>
                    <span class="status-data" id="sidebar-idade">---</span>
                </div>
            </div>
        </div>
        <div class="profile-section">
            <div class="actions-labels">
                <h3 class="section-title">Registro de Ações</h3>
                <h3 class="section-title">Usuário:</h3>
            </div>
            <div class="actions-content">
                <div class="action-buttons">
                    <button class="btn-circle btn-agua">Água</button>
                    <button class="btn-circle btn-comida">Comida</button>
                </div>
                <div class="user-log-box">
                    <p id="sidebar-log-usuario">ID usuário: - <br>Data/hora<br>alimentação</p>
                </div>
            </div>
        </div>
        <hr class="profile-divider">
        <div class="profile-section comments-section">
            <h3 class="section-title">Comentários:</h3>
            <div class="comment-input-row">
                <img src="/img/placeholder-user.png" alt="Seu Avatar" class="avatar-sm">
                <input type="text" class="comment-input" placeholder="Adicionar comentário...">
                <button class="btn-send-comment" title="Enviar">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
            <div class="comments-list">
                <div class="comment-item">
                    <img src="/img/placeholder-user.png" alt="Maria" class="avatar-sm">
                    <p><strong>Maria:</strong> Amei o cuidado com nossos humaninhos</p>
                </div>
            </div>
        </div>
    </aside>
    <div id="editModalContainer"></div>
</main>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/map-handler.js" asp-append-version="true"></script>
    <script src="~/js/dog-api-handler.js" asp-append-version="true"></script>
    <script src="~/js/ocorrencias.js" asp-append-version="true"></script>
}